    style SERVER_NODE fill:#141B24,stroke:#FF8A3D,color:#F2F5F8
    style FS_NODE fill:#141B24,stroke:#8B98A8,color:#F2F5F8
    style CLOUD fill:#0A0E13,stroke:#5B8DEF,color:#F2F5F8,stroke-dasharray: 4 3
