# Copy this file to .env and fill in your key to enable Gemini-powered RCA synthesis.
# The app works fully without this — it falls back to a deterministic,
# fully-cited rule-based synthesis template.

# GEMINI_API_KEY=xxxxxx
GEMINI_MODEL=gemini-2.0-flash

# GROQ_API_KEY=xxxx
# GROQ_API_KEY=xxxx

GROQ_API_KEY=""
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: change the port the dashboard runs on
PORT=8000
